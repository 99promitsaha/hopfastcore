# Privy (for wallet login)
VITE_PRIVY_APP_ID=

# Preferred backend API base (for local backend use http://localhost:8080/api)
VITE_HOPFAST_API_BASE_URL=

# Optional direct overrides (usually leave blank when using API base URL)
VITE_HOPFAST_QUOTE_PROXY_URL=

# Alchemy API key for fast token balance fetching (Ethereum, Base, Polygon)
# Get one free at https://dashboard.alchemy.com
# Without this, balances fall back to free public RPCs (slower, may rate-limit)
VITE_ALCHEMY_API_KEY=
